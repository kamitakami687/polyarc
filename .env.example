# Circle API key — from https://app.circle.com/
CIRCLE_API_KEY=

# OpenAI API key — from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Arc Testnet wallet private key (0x-prefixed hex)
# Fund this address with testnet USDC from https://faucet.circle.com
# before x402 payments will work
PRIVATE_KEY=

# Port (optional — defaults to 5000)
# PORT=5000
