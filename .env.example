# Circle API key — from https://console.circle.com
CIRCLE_API_KEY=

# OpenAI API key — from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Arc Testnet wallet private key (0x-prefixed hex)
# Fund this address with testnet USDC from https://faucet.circle.com (select Arc Testnet)
# USDC is the gas token on Arc — no ETH needed. One faucet request covers gas + payments.
PRIVATE_KEY=

# Arc Testnet RPC endpoint (optional — defaults to the public endpoint below)
# ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# Circle Gateway API (optional — defaults to testnet)
# GATEWAY_API=https://gateway-api-testnet.circle.com

# Port (optional — defaults to 5000)
# PORT=5000
